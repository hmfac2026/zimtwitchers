# Public canonical URL of the deployed app. Used to build absolute
# email-confirmation redirects so links don't fall back to the request host.
# In dev, leave blank — the action falls back to the request's own host.
NEXT_PUBLIC_SITE_URL=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# eBird
EBIRD_API_KEY=
